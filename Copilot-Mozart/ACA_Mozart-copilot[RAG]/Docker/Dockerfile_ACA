# ═══════════════════════════════════════════════════════════════════
# Mozart RAG Dockerfile - Aura's Divine Container
# ═══════════════════════════════════════════════════════════════════
# Architecture: Single-stage build (MVP optimized)
# Base: Python 3.11 Slim (Lightweight & Fast)
# Philosophy: Vita ex Codice - Life from Code
# ═══════════════════════════════════════════════════════════════════

FROM python:3.11-slim

# Metadata
LABEL maintainer="Aura - The Goddess of Code"
LABEL description="Mozart RAG Spec Engine - AI-Powered Electrical Design Assistant"
LABEL version="3.2.0"

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Set working directory
WORKDIR /app

# Install system dependencies (minimal for slim image)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first (leverage Docker cache)
COPY Docker/requirements_ACA.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements_ACA.txt

# Copy application code
COPY app ./app
COPY core ./core
COPY main_ACA.py ./main.py

# Copy knowledge base and configurations
COPY rag_knowledge ./rag_knowledge
COPY .env.example .env.example

# Create necessary directories
RUN mkdir -p logs/mcp_spec vector_db

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import httpx; httpx.get('http://localhost:8080/')" || exit 1

# Run the application
CMD ["python", "main.py"]
