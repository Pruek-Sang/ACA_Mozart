# ═══════════════════════════════════════════════════════════════════════════
# Dockerfile for Mozart Frontend - Cloud Run Version (Multi-stage Build)
# ═══════════════════════════════════════════════════════════════════════════
# This Dockerfile builds the React app inside Docker to ensure correct files
# are always included, regardless of GitHub Actions context issues.
# ═══════════════════════════════════════════════════════════════════════════

# Stage 1: Build the React app
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files first (for better caching)
COPY Copilot-Mozart/ACA_Mozart-copilot[RAG]/frontend_UI_UX/mozart-chat/package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY Copilot-Mozart/ACA_Mozart-copilot[RAG]/frontend_UI_UX/mozart-chat/ ./

# Build the app (uses .env.production automatically)
RUN npm run build

# Stage 2: Serve with nginx
FROM nginx:1.25-alpine

# Copy the simplified nginx config
COPY Copilot-Mozart/ACA_Mozart-copilot[RAG]/Docker/nginx-cloudrun.conf /etc/nginx/nginx.conf

# Copy built files from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/health || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
