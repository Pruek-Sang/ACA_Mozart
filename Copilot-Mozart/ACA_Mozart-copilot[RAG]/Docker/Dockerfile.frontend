# ═══════════════════════════════════════════════════════════════════════════
# ⚠️ NOT IN USE - DEPRECATED
# ═══════════════════════════════════════════════════════════════════════════
# This Dockerfile is NO LONGER USED by GitHub Actions
# 
# ACTIVE DOCKERFILES (as of Dec 2024):
# ┌──────────────┬────────────────────────────────────────────────────────────┐
# │ Service      │ Dockerfile Path                                            │
# ├──────────────┼────────────────────────────────────────────────────────────┤
# │ Frontend     │ Docker/Dockerfile.frontend-cloudrun  (EXPOSE 80)           │
# │ Gateway      │ Dockerfile.gateway                   (EXPOSE 8000)         │
# │ MCP Core     │ mcp_core_v2/Docker/Dockerfile        (EXPOSE 5001)         │
# │ Mozart RAG   │ Docker/Dockerfile_light              (EXPOSE 8080)         │
# └──────────────┴────────────────────────────────────────────────────────────┘
# ═══════════════════════════════════════════════════════════════════════════
# ORIGINAL DESCRIPTION:
# Dockerfile for Mozart Frontend (NGINX + React)
# This was used by old GitHub Actions to build the frontend Docker image
# ═══════════════════════════════════════════════════════════════════════════

FROM nginx:1.25-alpine

# Copy nginx configuration (from Docker/ at repo root)
COPY Docker/nginx.conf /etc/nginx/nginx.conf

# Copy built React app (from frontend-dist at repo root - copied by GitHub Actions)
COPY frontend-dist /usr/share/nginx/html

# Add health check file
RUN echo '{"status":"healthy","service":"mozart-frontend"}' > /usr/share/nginx/html/health.json

# Expose ports
EXPOSE 80 443

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost/health || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
