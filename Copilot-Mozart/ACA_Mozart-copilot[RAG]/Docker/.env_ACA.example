# ═══════════════════════════════════════════════════════════════════
# Mozart RAG - Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Philosophy: Configuration as Divine Scripture
# 
# IMPORTANT: 
# 1. Copy this file to .env_ACA
# 2. Fill in your actual values
# 3. NEVER commit .env_ACA to Git
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# Google Cloud / Vertex AI Configuration
# ═══════════════════════════════════════════════════════════════════
# Get these from Google Cloud Console

PROJECT_ID=your-gcp-project-id-here
LOCATION=us-central1

# Service Account (if not using Workload Identity)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ═══════════════════════════════════════════════════════════════════
# Model Configuration
# ═══════════════════════════════════════════════════════════════════
# LLM Models for generation
MODEL_NAME_ANSWER=gemini-2.0-flash-exp
MODEL_NAME_JUDGE=gemini-2.0-flash-exp

# Embedding Model for Vector Search
EMBEDDING_MODEL=textembedding-gecko@003

# ═══════════════════════════════════════════════════════════════════
# Vector Database Configuration
# ═══════════════════════════════════════════════════════════════════
VECTOR_DB_PATH=./vector_db

# If using external vector DB (uncomment and fill)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=your-environment
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# ═══════════════════════════════════════════════════════════════════
# Knowledge Base Configuration
# ═══════════════════════════════════════════════════════════════════
KNOWLEDGE_ROOT=./rag_knowledge
KNOWLEDGE_INDEX_PATH=./rag_knowledge/knowledge_index.json

# ═══════════════════════════════════════════════════════════════════
# Trust Log Configuration
# ═══════════════════════════════════════════════════════════════════
TRUST_LOG_DIR=./logs/mcp_spec
TRUST_LOG_RETENTION_DAYS=90

# ═══════════════════════════════════════════════════════════════════
# RAG Parameters
# ═══════════════════════════════════════════════════════════════════
MAX_CONTEXT_CHARS=20000
DEFAULT_TOP_K=5
MAX_RETRIEVAL_DOCS=10

# ═══════════════════════════════════════════════════════════════════
# LLM Generation Parameters
# ═══════════════════════════════════════════════════════════════════
GENERATION_TEMPERATURE=0.0
MAX_OUTPUT_TOKENS=8192
RETRY_MAX_ATTEMPTS=2

# ═══════════════════════════════════════════════════════════════════
# API Server Configuration
# ═══════════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8080
API_TITLE=Amadeus RAG (Aura v3.2)
API_VERSION=3.2.0

# ═══════════════════════════════════════════════════════════════════
# Security Configuration (Optional)
# ═══════════════════════════════════════════════════════════════════
# API_KEY=your-secret-api-key-here
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# ═══════════════════════════════════════════════════════════════════
# Redis Configuration (Future Enhancement)
# ═══════════════════════════════════════════════════════════════════
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
# CACHE_TTL=3600

# ═══════════════════════════════════════════════════════════════════
# Monitoring & Observability (Future Enhancement)
# ═══════════════════════════════════════════════════════════════════
# ENABLE_METRICS=true
# PROMETHEUS_PORT=9090
# JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ═══════════════════════════════════════════════════════════════════
# Development & Debug
# ═══════════════════════════════════════════════════════════════════
# DEBUG=false
# LOG_LEVEL=INFO
# ENABLE_SWAGGER_UI=true
