# ═══════════════════════════════════════════════════════════════════
# Mozart RAG - Environment Variables (EXAMPLE)
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git!
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# LLM Provider Configuration - Google AI
# ═══════════════════════════════════════════════════════════════════
GOOGLE_API_KEY=your_google_api_key_here

# ═══════════════════════════════════════════════════════════════════
# Model Configuration
# ═══════════════════════════════════════════════════════════════════
MODEL_NAME_ANSWER=gemini-2.5-flash-lite
MODEL_NAME_JUDGE=gemini-2.5-pro
EMBEDDING_MODEL=embedding-gecko-001

# ═══════════════════════════════════════════════════════════════════
# Vector Database Configuration
# ═══════════════════════════════════════════════════════════════════
VECTOR_DB_PATH=./vector_db

# ═══════════════════════════════════════════════════════════════════
# Knowledge Base Configuration
# ═══════════════════════════════════════════════════════════════════
KNOWLEDGE_ROOT=./rag_knowledge
KNOWLEDGE_INDEX_PATH=./rag_knowledge/knowledge_index.json

# ═══════════════════════════════════════════════════════════════════
# Supabase Configuration
# ═══════════════════════════════════════════════════════════════════
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# JWT Secret: Supabase Dashboard → Settings → API → JWT Secret
# Used to decode user tokens locally (no network call per request)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ═══════════════════════════════════════════════════════════════════
# MCP Core Connection
# ═══════════════════════════════════════════════════════════════════
MCP_CORE_URL=http://localhost:5001

# ═══════════════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=8080
DEBUG=false
