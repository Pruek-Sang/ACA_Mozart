# ═══════════════════════════════════════════════════════════════════
# ACA Mozart - Git Ignore
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# Environment Files (SECURITY - Contains API Keys!)
# ═══════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
**/.env
!.env.example

# ═══════════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# ═══════════════════════════════════════════════════════════════════
# IDE
# ═══════════════════════════════════════════════════════════════════
.idea/
.vscode/
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════════════
# Logs & Temporary Files
# ═══════════════════════════════════════════════════════════════════
*.log
logs/
*.tmp
*.temp
.cache/

# ═══════════════════════════════════════════════════════════════════
# Database & Vector DB
# ═══════════════════════════════════════════════════════════════════
*.db
*.sqlite3
vector_db/
chroma_db/
*.faiss

# ═══════════════════════════════════════════════════════════════════
# Test & Coverage
# ═══════════════════════════════════════════════════════════════════
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ═══════════════════════════════════════════════════════════════════
# Docker
# ═══════════════════════════════════════════════════════════════════
.docker/

# ═══════════════════════════════════════════════════════════════════
# OS Files
# ═══════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
