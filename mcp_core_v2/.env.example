# ═══════════════════════════════════════════════════════════════════
# MCP Core v2 - Environment Variables (EXAMPLE)
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git!
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# Google API (for any LLM features if needed)
# ═══════════════════════════════════════════════════════════════════
GOOGLE_API_KEY=your_google_api_key_here

# ═══════════════════════════════════════════════════════════════════
# API Settings
# ═══════════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=5001

# ═══════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════
# Thai Standard Settings
# ═══════════════════════════════════════════════════════════════════
DEFAULT_VOLTAGE=230V_1PH
DEFAULT_FREQUENCY=50Hz

# ═══════════════════════════════════════════════════════════════════
# NEC Standards
# ═══════════════════════════════════════════════════════════════════
NEC_VERSION=2023
NEC_VOLTAGE_DROP_BRANCH=0.03
NEC_VOLTAGE_DROP_FEEDER=0.02
